# Copy this file to campx/.env and fill in real values before running.
# cp campx/.env.example campx/.env

# PostgreSQL
POSTGRES_DB=campaign
POSTGRES_USER=campaign_user
POSTGRES_PASSWORD=campaign_pass

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin123

# DB connection (used by API, DS, orchestration containers)
DB_HOST=db
DB_PORT=5432

# Simulation parameters
N_CUSTOMERS=500
RANDOM_SEED=42
N_ROUNDS=5000
ALPHA=0.5
API_URL=http://back:8000
